{
  "name": "@open-quran/api",
  "version": "1.7.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "wrangler d1 migrations apply DB",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:seed": "cd .. && python3 scripts/seed_initial.py",
    "db:seed:quick": "cd .. && python3 scripts/seed_initial.py --max-ayah 50",
    "db:seed:preview": "cd .. && python3 scripts/seed_initial.py --preview",
    "db:seed:remote": "cd .. && python3 scripts/seed_initial.py --remote",
    "db:seed:dry-run": "cd .. && python3 scripts/seed_initial.py --dry-run",
    "db:reset": "rm -rf .wrangler/state/v3/d1/ && npm run db:migrate:local && npm run db:seed",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "verify": "bash scripts/verify-setup.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@cloudflare/workers-types": "^4.20240208.0",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "drizzle-orm": "^0.29.3",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "drizzle-kit": "^0.20.14",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3",
    "wrangler": "^3.28.0"
  }
}
